{
  "name": "aivilization",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "type": "module",
  "scripts": {
    "dev": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-node.ps1 scripts/dev-all.mjs",
    "dev:client": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-node.ps1 node_modules/vite/bin/vite.js --host 0.0.0.0",
    "server": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-node.ps1 --experimental-strip-types server/index.ts",
    "build": "tsc && vite build",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vite": "^7.0.0"
  }
}
