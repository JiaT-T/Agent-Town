{
  "installCommand": "echo \"Skipping install for API-only LLM proxy\"",
  "buildCommand": "echo \"Skipping build for API-only LLM proxy\"",
  "functions": {
    "api/llm/[type].js": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/api/llm/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "https://jiat-t.github.io"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET,POST,OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "content-type"
        }
      ]
    }
  ]
}
